{
  "name": "ozon-test-task",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.ts\"",
    "ci:format": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "lint:style": "stylelint \"src/**/*.{css,scss}\" --fix",
    "prepare": "husky",
    "style": "sass -w src/app/styles/index.scss src/app/styles/index.css",
    "deploy": "gh-pages -d dist"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**/*.{json, css, scss, html, md}": [
      "prettier --write"
    ]
  },
